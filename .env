# The environment Craft is currently running in ('dev', 'staging', 'production', etc.)
ENVIRONMENT=dev

# The secure key Craft will use for hashing and encrypting data
# NOTE: If you have the original production SECURITY_KEY, replace the value below
# with it, otherwise existing encrypted data in the database will not decrypt.
SECURITY_KEY=96d871a4d653e8af02afddc0b8e53efc

# Database connection (DDEV defaults: host "db", user/pass "db/db", database "db")
DB_DSN=mysql:host=db;port=3306;dbname=db
DB_USER=db
DB_PASSWORD=db
DB_SCHEMA=public
DB_TABLE_PREFIX=
