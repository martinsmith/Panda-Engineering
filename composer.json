{
  "require": {
    "adigital/cookie-consent-banner": "^2.0",
    "craftcms/aws-s3": "^2.0",
    "craftcms/cms": "^4.0",
    "craftcms/postmark": "^3.0",
    "craftcms/redactor": "^3.0",
    "mmikkel/child-me": "^1.3.3",
    "mmikkel/retcon": "^2.8",
    "nystudio107/craft-seomatic": "^4.0",
    "topshelfcraft/wordsmith": "^4.0",
    "verbb/cp-nav": "^4.0",
    "verbb/redactor-tweaks": "^3.0",
    "verbb/super-table": "^3.0",
    "vlucas/phpdotenv": "^5.4.0"
  },
  "require-dev": {
    "yiisoft/yii2-shell": "^2.0.3"
  },
  "autoload": {
    "psr-4": {
      "modules\\": "modules/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "platform": {
      "php": "8.2"
    },
    "allow-plugins": {
      "craftcms/plugin-installer": true,
      "yiisoft/yii2-composer": true,
      "composer/package-versions-deprecated": true
    }
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ]
  }
}
